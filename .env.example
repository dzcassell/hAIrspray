# ---------------------------------------------------------------------------
# hAIrspray configuration
# Copy to `.env` and edit as needed.
# ---------------------------------------------------------------------------

# How long to wait between single requests (uniform random, seconds).
MIN_INTERVAL_SEC=30
MAX_INTERVAL_SEC=180

# Occasionally fire a burst of requests to simulate an active user session.
# Probability is evaluated once per iteration. Size and gap are both uniform.
BURST_PROBABILITY=0.15
BURST_MIN_SIZE=3
BURST_MAX_SIZE=7
BURST_GAP_MIN_SEC=1
BURST_GAP_MAX_SEC=4

# Which target categories to include.
# Comma-separated subset of: llm_api, chatbot_ui, media_gen, aggregator, real_response
CATEGORIES=llm_api,chatbot_ui,media_gen,aggregator,real_response

# Keep-alive / concurrency.
MAX_CONCURRENT=1
HTTP_TIMEOUT_SEC=30

# Observability.
LOG_LEVEL=INFO
HEALTH_PORT=8080
# Host-side port for the web UI / health / metrics endpoint. Defaults
# to 8090 because 8080 is commonly taken (cadvisor, etc.).
HEALTH_HOST_PORT=8090
# Host bind address. 0.0.0.0 = LAN-accessible (default, since the UI
# expects to be reachable from your workstation). Set to 127.0.0.1 for
# loopback-only.
HEALTH_BIND=0.0.0.0

# Master switch for the keyless-real-response providers
# (Pollinations, DuckDuckGo AI Chat). Turn off if you only want probes.
ENABLE_REAL_RESPONSES=true

# TLS certificate verification for outbound requests.
#
# PREFERRED: drop your SASE/NGFW re-sign CA into ./certs/ (see
# certs/README.md) — hAIrspray will then verify with FULL TLS
# checking against a combined bundle of certifi + your CA. The
# TLS_VERIFY setting below is then irrelevant (custom bundle takes
# priority), but leaving it at true is a good belt-and-braces.
#
# If you cannot obtain your fabric's CA for some reason:
#   TLS_VERIFY=false  → verification bypassed entirely (last resort;
#                       container can't detect MitM on its own).
#   TLS_VERIFY=true   → stock Mozilla trust store (only works outside
#                       any MitM-inspecting fabric).
#
# The container's boot log always states which mode won; grep for
# 'tls_custom_ca', 'tls_system_verify', or 'tls_verify_disabled'.
TLS_VERIFY=false
